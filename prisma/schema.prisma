generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  SGQ
  USER
  VIEWER
  TICKET
}

enum MaintenanceTicketStatus {
  OPEN
  IN_PROGRESS
  PAUSED
  DONE
  VALIDATED
  CANCELED
}

enum MaintenanceTicketPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum TaskFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  FOUR_MONTHLY
  SEMIANNUAL
  ANNUAL
  BIENNIAL
  FIVE_YEAR
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum EquipmentStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  DISCARDED
}

enum DocumentType {
  INVOICE
  WARRANTY
  MANUAL
  CERTIFICATE
  CONTRACT
  OTHER
}

enum ExpenseStatus {
  PENDING
  PAID
  CANCELED
}

enum SGQStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum MaintenanceType {
  INTERNAL
  EXTERNAL
}

enum MaintenanceScheduleStatus {
  SCHEDULED
  DONE
  CANCELED
}

enum InterventionKind {
  INSPECTION
  MAINTENANCE
}

enum ChecklistResponseStatus {
  OK
  NOT_OK
  NA
}

enum VehicleFuel {
  GASOLINE
  DIESEL
  HYBRID
  ELECTRIC
  LPG
  OTHER
}

enum VehicleServiceType {
  MAINTENANCE
  REVISION
  INSPECTION
  COST
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  PAUSED
  DONE
  VALIDATED
  CANCELED
}

model User {
  id              String   @id @default(cuid())
  name            String
  username        String?  @unique
  email           String
  password        String?
  pin             String?
  hourlyRate      Decimal  @default(0) @db.Decimal(10, 2)
  notifyStartTime String?  @default("08:00")
  notifyEndTime   String?  @default("18:00")
  notifyDays      String?  @default("1,2,3,4,5")
  telegramChatId  String?
  telegramEnabled Boolean  @default(true)
  role            UserRole @default(USER)
  active          Boolean  @default(true)

  tasksCreated          Task[]                  @relation("TaskCreatedBy")
  tasksAssigned         Task[]                  @relation("TaskAssignedTo")
  expenses              Expense[]
  maintenanceLogs       MaintenanceLog[]
  calibrationLogs       CalibrationLog[]
  documents             Document[]
  sgqRecordsCreated     SGQRecord[]
  sessions              Session[]
  ticketsOpened         MaintenanceTicket[]     @relation("TicketOpenedBy")
  ticketsAssigned       MaintenanceTicket[]     @relation("TicketAssignedTo")
  ticketsStarted        MaintenanceTicket[]     @relation("TicketStartedBy")
  ticketsCompleted      MaintenanceTicket[]     @relation("TicketCompletedBy")
  ticketsValidated      MaintenanceTicket[]     @relation("TicketValidatedBy")
  ticketEquipmentAccess TicketEquipmentAccess[]
  notifications         Notification[]
  pushSubscriptions     PushSubscription[]
  consumableMovements   ConsumableMovement[]
  vacations             Vacation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model Equipment {
  id                      String          @id @default(cuid())
  name                    String
  code                    String?         @unique
  category                String
  brand                   String?
  model                   String?
  serialNumber            String?
  supplier                String?
  location                String?
  responsibleDepartment   String?
  isMeasurementMonitoring Boolean         @default(false)
  regulatoryRequirements  Boolean         @default(false)
  regulatoryDetails       String?
  parentEquipmentId       String?
  parentEquipment         Equipment?      @relation("EquipmentHierarchy", fields: [parentEquipmentId], references: [id], onDelete: SetNull)
  childEquipment          Equipment[]     @relation("EquipmentHierarchy")
  equipmentTypeId         String?
  equipmentType           EquipmentType?  @relation(fields: [equipmentTypeId], references: [id], onDelete: SetNull)
  purchaseDate            DateTime?
  warrantyUntil           DateTime?
  status                  EquipmentStatus @default(ACTIVE)
  notes                   String?

  tasks                      Task[]
  interventionPlans          EquipmentInterventionPlan[]
  interventionLogs           EquipmentInterventionLog[]
  internalMaintenanceRecords InternalMaintenanceRecord[]
  maintenanceLogs            MaintenanceLog[]
  maintenanceSchedules       MaintenanceSchedule[]
  workOrders                 WorkOrder[]
  tickets                    MaintenanceTicket[]
  ticketUserAccess           TicketEquipmentAccess[]
  calibrationLogs            CalibrationLog[]
  expenses                   Expense[]
  documents                  Document[]
  consumables                Consumable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EquipmentType {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  equipment          Equipment[]
  checklistTemplates ChecklistTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChecklistTemplate {
  id      String  @id @default(cuid())
  title   String
  version String  @default("1.0")
  active  Boolean @default(true)
  notes   String?

  equipmentTypeId String
  equipmentType   EquipmentType @relation(fields: [equipmentTypeId], references: [id], onDelete: Cascade)

  items      ChecklistItem[]
  records    InternalMaintenanceRecord[]
  workOrders WorkOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

model ChecklistItem {
  id                String  @id @default(cuid())
  order             Int
  check             String
  expectedCondition String
  photoRequired     Boolean @default(false)
  active            Boolean @default(true)

  templateId String
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  responses ChecklistResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@index([active])
}

model InternalMaintenanceRecord {
  id          String   @id @default(cuid())
  documentNo  String?
  year        Int?
  month       Int?
  performedAt DateTime @default(now())
  responsible String?
  result      String?
  notes       String?

  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  templateId String
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)

  responses ChecklistResponse[]
  workOrder WorkOrder?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([performedAt])
  @@index([year, month])
}

model ChecklistResponse {
  id     String                  @id @default(cuid())
  status ChecklistResponseStatus
  obs    String?

  recordId String
  record   InternalMaintenanceRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  itemId String
  item   ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Restrict)

  photos ChecklistPhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([recordId, itemId])
}

model ChecklistPhoto {
  id       String  @id @default(cuid())
  fileUrl  String
  fileName String?
  caption  String?

  responseId String
  response   ChecklistResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Task {
  id          String         @id @default(cuid())
  title       String
  description String?
  frequency   TaskFrequency?
  isRecurring Boolean        @default(true)
  status      TaskStatus     @default(PENDING)

  startDate DateTime
  dueDate   DateTime?
  dueTime   String?
  lastDone  DateTime?
  nextDue   DateTime?

  equipmentId String?
  equipment   Equipment? @relation(fields: [equipmentId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("TaskCreatedBy", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MaintenanceLog {
  id          String          @id @default(cuid())
  title       String
  description String?
  type        MaintenanceType @default(INTERNAL)
  date        DateTime        @default(now())
  cost        Decimal?        @db.Decimal(10, 2)
  supplier    String?
  costCenter  String?
  performedBy String?
  nextDate    DateTime?
  notes       String?

  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  documents Document[]
  workOrder WorkOrder?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EquipmentInterventionPlan {
  id        String           @id @default(cuid())
  kind      InterventionKind
  type      MaintenanceType
  frequency TaskFrequency
  actions   String
  active    Boolean          @default(true)
  notes     String?

  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind])
  @@index([type])
}

model EquipmentInterventionLog {
  id          String           @id @default(cuid())
  kind        InterventionKind
  type        MaintenanceType
  title       String
  performedAt DateTime         @default(now())
  performedBy String?
  actionsDone String
  result      String?
  notes       String?

  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([performedAt])
  @@index([kind])
  @@index([type])
}

model MaintenanceSchedule {
  id          String                    @id @default(cuid())
  title       String
  description String?
  type        MaintenanceType           @default(INTERNAL)
  status      MaintenanceScheduleStatus @default(SCHEDULED)
  scheduledAt DateTime
  frequency   TaskFrequency
  supplier    String?
  costCenter  String?
  notes       String?

  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  workOrder WorkOrder?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scheduledAt])
  @@index([type])
  @@index([status])
}

model WorkOrder {
  id               String          @id @default(cuid())
  sequence         Int             @unique @default(autoincrement())
  number           String          @unique
  title            String
  type             MaintenanceType @default(INTERNAL)
  status           WorkOrderStatus @default(OPEN)
  openedAt         DateTime        @default(now())
  startedAt        DateTime?
  pausedAt         DateTime?
  closedAt         DateTime?
  validatedAt      DateTime?
  totalWorkSeconds Int             @default(0)
  lastResumedAt    DateTime?
  performedBy      String?
  actionsDone      String?
  result           String?
  notes            String?

  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  scheduleId String?              @unique
  schedule   MaintenanceSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  templateId String?
  template   ChecklistTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  checklistRecordId String?                    @unique
  checklistRecord   InternalMaintenanceRecord? @relation(fields: [checklistRecordId], references: [id], onDelete: SetNull)

  maintenanceLogId String?         @unique
  maintenanceLog   MaintenanceLog? @relation(fields: [maintenanceLogId], references: [id], onDelete: SetNull)

  documents           Document[]
  ticket              MaintenanceTicket?
  consumableMovements ConsumableMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([openedAt])
}

model MaintenanceTicket {
  id             String                    @id @default(cuid())
  number         String                    @unique
  title          String
  problem        String
  solution       String?
  status         MaintenanceTicketStatus   @default(OPEN)
  priority       MaintenanceTicketPriority @default(NORMAL)
  machineStopped Boolean                   @default(true)
  location       String?
  observations   String?

  totalWorkSeconds Int     @default(0)
  downtimeSeconds  Int     @default(0)
  laborCost        Decimal @default(0) @db.Decimal(10, 2)
  consumableCost   Decimal @default(0) @db.Decimal(10, 2)
  totalCost        Decimal @default(0) @db.Decimal(10, 2)

  openedAt    DateTime  @default(now())
  startedAt   DateTime?
  pausedAt    DateTime?
  completedAt DateTime?
  validatedAt DateTime?

  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  openedById String?
  openedBy   User?   @relation("TicketOpenedBy", fields: [openedById], references: [id], onDelete: SetNull)

  assignedToId String?
  assignedTo   User?   @relation("TicketAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  startedById String?
  startedBy   User?   @relation("TicketStartedBy", fields: [startedById], references: [id], onDelete: SetNull)

  completedById String?
  completedBy   User?   @relation("TicketCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  validatedById String?
  validatedBy   User?   @relation("TicketValidatedBy", fields: [validatedById], references: [id], onDelete: SetNull)

  workOrderId String?    @unique
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  consumables         TicketConsumableUsage[]
  consumableMovements ConsumableMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([openedAt])
  @@index([equipmentId])
}

model Vacation {
  id            String   @id @default(cuid())
  employeeName  String
  startDate     DateTime
  endDate       DateTime
  days          Decimal  @default(0) @db.Decimal(6, 2)
  absenceHours  Decimal  @default(0) @db.Decimal(6, 2)
  bankHoursUsed Decimal  @default(0) @db.Decimal(6, 2)
  status        String   @default("PLANNED")
  notes         String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  color String? @default("#14b8a6")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate])
  @@index([endDate])
  @@index([userId])
}

model EnvironmentalImport {
  id               String    @id @default(cuid())
  fileName         String
  fileHash         String?
  source           String    @default("MANUAL")
  sourceUrl        String?
  sourceModifiedAt DateTime?
  rowsCount        Int       @default(0)
  importedAt       DateTime  @default(now())

  readings EnvironmentalReading[]

  @@unique([fileHash])
  @@index([source])
  @@index([importedAt])
}

model EnvironmentalReading {
  id        String   @id @default(cuid())
  timestamp DateTime
  hour      String?
  sensor    String
  zone      String   @default("SEM_ZONA")
  type      String
  value     Decimal  @db.Decimal(10, 2)
  status    String   @default("OK")

  importId String?
  import   EnvironmentalImport? @relation(fields: [importId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([timestamp, sensor, type])
  @@index([timestamp])
  @@index([type, sensor])
  @@index([type, zone])
  @@index([zone])
  @@index([status])
}

model EnvironmentalSettings {
  id                  String   @id @default("default")
  alertStartTime      String   @default("06:00")
  alertEndTime        String   @default("22:00")
  includeSaturday     Boolean  @default(false)
  includeSunday       Boolean  @default(false)
  sharePointFolderUrl String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model TicketEquipmentAccess {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, equipmentId])
  @@index([equipmentId])
}

model TicketConsumableUsage {
  id       String  @id @default(cuid())
  quantity Decimal @default(0) @db.Decimal(10, 2)
  unitCost Decimal @default(0) @db.Decimal(10, 2)
  notes    String?

  ticketId String
  ticket   MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  consumableId String
  consumable   Consumable @relation(fields: [consumableId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([consumableId])
}

model Notification {
  id     String    @id @default(cuid())
  title  String
  body   String?
  href   String?
  readAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, readAt])
  @@index([createdAt])
}

model PushSubscription {
  id        String  @id @default(cuid())
  endpoint  String  @unique
  p256dh    String
  auth      String
  userAgent String?
  active    Boolean @default(true)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([active])
}

model CalibrationLog {
  id              String    @id @default(cuid())
  title           String
  certificateNo   String?
  calibrationDate DateTime
  nextDueDate     DateTime?
  result          String?
  approved        Boolean   @default(true)
  notes           String?

  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Consumable {
  id           String  @id @default(cuid())
  name         String
  category     String
  unit         String
  currentStock Decimal @default(0) @db.Decimal(10, 2)
  minimumStock Decimal @default(0) @db.Decimal(10, 2)
  unitCost     Decimal @default(0) @db.Decimal(10, 2)
  folderUrl    String?
  location     String?
  supplier     String?
  notes        String?

  equipmentId String?
  equipment   Equipment? @relation(fields: [equipmentId], references: [id], onDelete: SetNull)

  movements    ConsumableMovement[]
  ticketUsages TicketConsumableUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConsumableMovement {
  id       String   @id @default(cuid())
  type     String
  quantity Decimal  @db.Decimal(10, 2)
  reason   String?
  date     DateTime @default(now())

  consumableId String
  consumable   Consumable @relation(fields: [consumableId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  ticketId String?
  ticket   MaintenanceTicket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  workOrderId String?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([ticketId])
  @@index([workOrderId])
}

model Expense {
  id         String        @id @default(cuid())
  date       DateTime      @default(now())
  title      String
  category   String
  supplier   String?
  costCenter String?
  amount     Decimal       @db.Decimal(10, 2)
  status     ExpenseStatus @default(PAID)
  notes      String?

  equipmentId String?
  equipment   Equipment? @relation(fields: [equipmentId], references: [id], onDelete: SetNull)

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MonthlyBill {
  id       String  @id @default(cuid())
  name     String
  category String
  amount   Decimal @db.Decimal(10, 2)
  dueDay   Int
  active   Boolean @default(true)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Budget {
  id       String  @id @default(cuid())
  year     Int
  month    Int?
  category String
  planned  Decimal @db.Decimal(10, 2)
  spent    Decimal @default(0) @db.Decimal(10, 2)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month, category])
}

model Document {
  id         String       @id @default(cuid())
  title      String
  type       DocumentType
  fileUrl    String?
  fileName   String?
  expiryDate DateTime?
  notes      String?

  equipmentId String?
  equipment   Equipment? @relation(fields: [equipmentId], references: [id], onDelete: SetNull)

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  expenseId String?
  expense   Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  maintenanceLogId String?
  maintenanceLog   MaintenanceLog? @relation(fields: [maintenanceLogId], references: [id], onDelete: SetNull)

  calibrationLogId String?
  calibrationLog   CalibrationLog? @relation(fields: [calibrationLogId], references: [id], onDelete: SetNull)

  workOrderId String?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SGQRecord {
  id          String    @id @default(cuid())
  code        String?   @unique
  title       String
  description String?
  status      SGQStatus @default(DRAFT)
  version     String    @default("1.0")
  approvedAt  DateTime?
  notes       String?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id     String      @id @default(cuid())
  brand  String
  model  String
  plate  String      @unique
  fuel   VehicleFuel
  year   Int?
  driver String?
  notes  String?

  kmLogs    VehicleKmLog[]
  services  VehicleService[]
  expenses  Expense[]
  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VehicleKmLog {
  id       String   @id @default(cuid())
  date     DateTime
  odometer Int
  notes    String?

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([date])
  @@index([odometer])
}

model VehicleService {
  id          String             @id @default(cuid())
  type        VehicleServiceType
  title       String
  date        DateTime
  odometer    Int?
  cost        Decimal?           @db.Decimal(10, 2)
  supplier    String?
  nextDueDate DateTime?
  nextDueKm   Int?
  notes       String?

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([date])
  @@index([nextDueDate])
  @@index([nextDueKm])
}
